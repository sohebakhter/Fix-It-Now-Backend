model Review {
  id         String  @id @default(uuid())
  customerId String
  user       User    @relation(fields: [customerId], references: [id])
  serviceId  String
  service    Service @relation(fields: [serviceId], references: [id])
  content    String
  rating     Float
  review     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reviews")
}
