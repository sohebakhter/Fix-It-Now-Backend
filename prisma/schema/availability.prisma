model Availability {
  id                String             @id @default(uuid())
  technicianId      String
  technicianProfile TechnicianProfile? @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  date      DateTime
  startTime String
  endTime   String

  isBooked Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking?

  @@map("availabilities")
}
