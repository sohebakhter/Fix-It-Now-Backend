model Service {
  id           String        @id @default(uuid())
  technicianId String
  user         User          @relation(fields: [technicianId], references: [id], onDelete: Cascade)
  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  title        String
  description  String?
  location     String
  price        Float
  status       ServiceStatus @default(PENDING)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  reviews   Review[]
  bookings  Booking[]

  @@map("services")
}
