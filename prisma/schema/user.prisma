model User {
    id       String     @id @default(uuid())
    name     String
    email    String     @unique
    password String
    role     UserRole   @default(CUSTOMER)
    status   UserStatus @default(UN_BAN)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    technicianProfile TechnicianProfile?

    @@map("users")
}
